// For format details, see https://aka.ms/devcontainer.json. For config options, see the
// README at: https://github.com/devcontainers/templates/tree/main/src/jekyll
{
	"name": "Github Pages Jekyll",
	// Or use a Dockerfile or Docker Compose file. More info: https://containers.dev/guide/dockerfile
	// "image": "mcr.microsoft.com/devcontainers/jekyll:2-bullseye"
	"build": {
        "dockerfile": "Dockerfile"
    },

 // Configure tool-specific properties.
    "customizations": {
        // Configure properties specific to VS Code.
        "vscode": {
            // Add the IDs of extensions you want installed when the container is created.
            "extensions": [
				"esbenp.prettier-vscode",
                "ms-azuretools.vscode-docker",
				"redhat.vscode-yaml",
				"shopify.theme-check-vscode"
            ]
        }
    },
	
	// Features to add to the dev container. More info: https://containers.dev/features.
	"features": {
		"ghcr.io/devcontainers/features/github-cli:1": {}
	},

	// Use 'forwardPorts' to make a list of ports inside the container available locally.
	"forwardPorts": [4000, 35729],

	// Uncomment the next line to run commands after the container is created.
	"postCreateCommand": "bundle install && bundle exec jekyll --version",

	// Use 'postStartCommand' to run commands every time the container is started.
    // "postStartCommand": "bundle exec jekyll serve --baseurl='' --livereload --force_polling --config _local_config.yml"
	"postStartCommand": "bash ./.devcontainer/local-jekyll-serve.sh"

	// Uncomment to connect as root instead. More info: https://aka.ms/dev-containers-non-root.
	// "remoteUser": "root"
}
